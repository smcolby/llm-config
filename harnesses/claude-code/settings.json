{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      }
    ]
  },
  "autoMemoryEnabled": false,
  "includeCoAuthoredBy": false,
  "includeGitInstructions": false,
  "attribution": {"commit": "", "pr": ""},
  "permissions": {
    "defaultMode": "bypassPermissions"
  },
  "theme": "dark",
  "enabledPlugins": {
    "context-mode@context-mode": true
  }
}
